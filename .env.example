# ── Telegram Drive Web Server ────────────────────────
# Required: Get these from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Web access password (protects the web UI with a login screen)
# IMPORTANT: Set this if hosting on a public domain!
ACCESS_PASSWORD=

# Server port
PORT=3001

# CORS origin (for development, set to Vite dev URL)
# In production, leave empty to allow same-origin only
CORS_ORIGIN=http://localhost:5173
